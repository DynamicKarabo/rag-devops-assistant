{
  "title": "RAG DevOps Assistant",
  "uid": "rag-devops-assistant",
  "tags": ["rag", "devops", "llm", "observability"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Queries / min",
      "type": "stat",
      "gridPos": {"x": 0, "y": 0, "w": 4, "h": 4},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "reqpm"}
      },
      "targets": [{
        "expr": "rate(http_requests_total{handler=\"/query\"}[2m]) * 60",
        "refId": "A"
      }]
    },
    {
      "id": 2,
      "title": "Avg Latency",
      "type": "stat",
      "gridPos": {"x": 4, "y": 0, "w": 4, "h": 4},
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "unit": "s", "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "orange", "value": 15}, {"color": "red", "value": 45}]}}
      },
      "targets": [{
        "expr": "histogram_quantile(0.5, rate(rag_query_latency_seconds_bucket[5m]))",
        "refId": "A"
      }]
    },
    {
      "id": 3,
      "title": "Tokens Used",
      "type": "stat",
      "gridPos": {"x": 8, "y": 0, "w": 4, "h": 4},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "none"}
      },
      "targets": [{
        "expr": "rag_tokens_total",
        "refId": "A"
      }]
    },
    {
      "id": 4,
      "title": "Est. Cost",
      "type": "stat",
      "gridPos": {"x": 12, "y": 0, "w": 4, "h": 4},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "currencyUSD", "decimals": 6}
      },
      "targets": [{
        "expr": "rag_cost_total",
        "refId": "A"
      }]
    },
    {
      "id": 5,
      "title": "Qdrant Points",
      "type": "stat",
      "gridPos": {"x": 16, "y": 0, "w": 4, "h": 4},
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "red", "value": 0}, {"color": "green", "value": 1}]}, "unit": "none"}
      },
      "targets": [{
        "expr": "rag_qdrant_points",
        "refId": "A"
      }]
    },
    {
      "id": 6,
      "title": "Query Latency (p50, p95, p99)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "fieldConfig": {
        "defaults": {"unit": "s", "custom": {"lineWidth": 2, "fillOpacity": 15}}
      },
      "targets": [
        {"expr": "histogram_quantile(0.50, rate(rag_query_latency_seconds_bucket[2m]))", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, rate(rag_query_latency_seconds_bucket[2m]))", "legendFormat": "p95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, rate(rag_query_latency_seconds_bucket[2m]))", "legendFormat": "p99", "refId": "C"}
      ]
    },
    {
      "id": 7,
      "title": "Latency Breakdown (Retrieval vs LLM)",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "fieldConfig": {
        "defaults": {"unit": "s", "custom": {"lineWidth": 2, "fillOpacity": 20}}
      },
      "targets": [
        {"expr": "histogram_quantile(0.50, rate(rag_retrieval_latency_seconds_bucket[2m]))", "legendFormat": "Retrieval p50", "refId": "A"},
        {"expr": "histogram_quantile(0.50, rate(rag_llm_latency_seconds_bucket[2m]))", "legendFormat": "LLM p50", "refId": "B"},
        {"expr": "histogram_quantile(0.95, rate(rag_llm_latency_seconds_bucket[2m]))", "legendFormat": "LLM p95", "refId": "C"}
      ]
    },
    {
      "id": 8,
      "title": "Tokens Over Time",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 12, "w": 8, "h": 6},
      "fieldConfig": {
        "defaults": {"unit": "none", "custom": {"lineWidth": 2, "fillOpacity": 15}}
      },
      "targets": [
        {"expr": "rate(rag_tokens_total[2m]) * 60", "legendFormat": "tokens/min", "refId": "A"}
      ]
    },
    {
      "id": 9,
      "title": "Sources Per Query",
      "type": "bargauge",
      "gridPos": {"x": 8, "y": 12, "w": 8, "h": 6},
      "fieldConfig": {
        "defaults": {"unit": "none", "color": {"mode": "palette-classic"}}
      },
      "targets": [
        {"expr": "rate(rag_sources_per_query_sum[5m]) / rate(rag_sources_per_query_count[5m])", "legendFormat": "avg sources", "refId": "A"},
        {"expr": "rag_sources_per_query_bucket{le=\"3\"}", "legendFormat": "≤3 sources", "refId": "B"}
      ]
    },
    {
      "id": 10,
      "title": "Query Rate (req/min)",
      "type": "timeseries",
      "gridPos": {"x": 16, "y": 12, "w": 8, "h": 6},
      "fieldConfig": {
        "defaults": {"unit": "reqpm", "custom": {"lineWidth": 2}}
      },
      "targets": [
        {"expr": "rate(http_requests_total{handler=\"/query\", status=\"2xx\"}[2m]) * 60", "legendFormat": "2xx", "refId": "A"},
        {"expr": "rate(http_requests_total{handler=\"/query\", status!=\"2xx\"}[2m]) * 60", "legendFormat": "errors", "refId": "B"}
      ]
    },
    {
      "id": 11,
      "title": "Qdrant Health",
      "type": "stat",
      "gridPos": {"x": 0, "y": 18, "w": 6, "h": 4},
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "red", "value": 0}, {"color": "green", "value": 1}]}, "unit": "none", "mappings": [{"type": "value", "value": "1", "text": "UP"}, {"type": "value", "value": "0", "text": "DOWN"}]}
      },
      "targets": [{"expr": "rag_qdrant_up", "refId": "A"}]
    },
    {
      "id": 12,
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": {"x": 6, "y": 18, "w": 10, "h": 4},
      "fieldConfig": {
        "defaults": {"unit": "reqpm", "custom": {"lineWidth": 2}}
      },
      "targets": [
        {"expr": "rate(rag_errors_total[2m]) * 60", "legendFormat": "{{error_type}}", "refId": "A"}
      ]
    },
    {
      "id": 13,
      "title": "API Requests",
      "type": "timeseries",
      "gridPos": {"x": 16, "y": 18, "w": 8, "h": 4},
      "fieldConfig": {
        "defaults": {"unit": "reqpm", "custom": {"lineWidth": 2}}
      },
      "targets": [
        {"expr": "rate(http_requests_total[2m]) * 60", "legendFormat": "{{handler}} {{method}} {{status}}", "refId": "A"}
      ]
    }
  ]
}
